<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aastha Advisors — Audit, Tax & Advisory Services in India</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #1a1a1a;
  --ink-soft: #4a4a4a;
  --ink-muted: #8a8a8a;
  --line: #e8e6e1;
  --bg: #fafaf7;
  --paper: #ffffff;
  --accent: #c84b1f;
  --accent-soft: #f5ebe5;
  --serif: 'Fraunces', Georgia, serif;
  --sans: 'Inter', system-ui, sans-serif;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: var(--sans); color: var(--ink); background: var(--bg); -webkit-font-smoothing: antialiased; line-height: 1.6; overflow-x: hidden; }
a { text-decoration: none; color: inherit; }
img { display: block; max-width: 100%; }

/* HEADER */
.header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(250,250,247,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid transparent; transition: border-color 0.4s; }
.header.scrolled { border-bottom-color: var(--line); }
.header-inner { max-width: 1280px; margin: 0 auto; padding: 20px 40px; display: flex; align-items: center; justify-content: space-between; }
.logo { display: flex; align-items: baseline; gap: 8px; font-family: var(--serif); font-size: 22px; font-weight: 500; letter-spacing: -0.02em; }
.logo-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent); display: inline-block; }
nav { display: flex; gap: 36px; }
nav a { font-size: 14px; color: var(--ink-soft); transition: color 0.3s; }
nav a:hover { color: var(--ink); }
.cta-btn { background: var(--ink); color: var(--paper); padding: 10px 22px; font-size: 13px; font-weight: 500; border: none; cursor: pointer; transition: background 0.3s; border-radius: 999px; }
.cta-btn:hover { background: var(--accent); }
.burger { display: none; background: none; border: none; padding: 8px; cursor: pointer; }
.burger span { display: block; width: 22px; height: 1.5px; background: var(--ink); margin: 5px 0; }

/* HERO */
.hero { padding: 160px 40px 100px; max-width: 1280px; margin: 0 auto; }
.hero-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 80px; align-items: end; }
.hero-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 32px; display: inline-flex; align-items: center; gap: 12px; opacity: 0; transform: translateY(10px); animation: rise 0.8s 0.2s ease forwards; }
.hero-eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--accent); }
.hero h1 { font-family: var(--serif); font-weight: 400; font-size: clamp(38px, 5.2vw, 76px); line-height: 1.05; letter-spacing: -0.025em; margin-bottom: 32px; }
.hero h1 .word { display: inline-block; opacity: 0; transform: translateY(20px); animation: rise 0.9s ease forwards; }
.hero h1 .italic { font-style: italic; color: var(--accent); }
.hero-sub { font-size: 17px; color: var(--ink-soft); max-width: 540px; line-height: 1.7; margin-bottom: 40px; opacity: 0; transform: translateY(15px); animation: rise 0.8s 1.2s ease forwards; }
.hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; opacity: 0; transform: translateY(15px); animation: rise 0.8s 1.4s ease forwards; }
.btn-primary { background: var(--ink); color: var(--paper); padding: 16px 32px; font-size: 14px; font-weight: 500; border-radius: 999px; transition: background 0.3s; display: inline-flex; align-items: center; gap: 10px; border: none; cursor: pointer; }
.btn-primary:hover { background: var(--accent); }
.btn-primary svg { transition: transform 0.3s; }
.btn-primary:hover svg { transform: translateX(3px); }
.btn-ghost { color: var(--ink); padding: 16px 8px; font-size: 14px; font-weight: 500; display: inline-flex; align-items: center; gap: 8px; border-bottom: 1px solid transparent; transition: border-color 0.3s; }
.btn-ghost:hover { border-color: var(--ink); }

/* Hero visual */
.hero-visual { aspect-ratio: 3/4; width: 100%; overflow: hidden; position: relative; background: var(--ink); opacity: 0; transform: translateY(30px); animation: rise 1.2s 0.7s ease forwards; display: block; }
.hero-visual img { width: 100%; height: 100%; object-fit: cover; transition: transform 8s ease; display: block; }
.hero-visual:hover img { transform: scale(1.04); }
.hero-visual-tag { position: absolute; bottom: 20px; left: 20px; right: 20px; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); padding: 14px 18px; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); display: flex; justify-content: space-between; align-items: center; }
.hero-visual-tag em { font-family: var(--serif); font-style: italic; text-transform: none; letter-spacing: 0; color: var(--accent); font-size: 14px; }

/* Hero meta */
.hero-meta { margin-top: 80px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; padding-top: 40px; border-top: 1px solid var(--line); opacity: 0; transform: translateY(15px); animation: rise 0.8s 1.6s ease forwards; }
.hero-meta-item .num { font-family: var(--serif); font-size: 36px; font-weight: 500; letter-spacing: -0.02em; }
.hero-meta-item .lab { font-size: 13px; color: var(--ink-muted); margin-top: 6px; }

/* SECTIONS */
section { padding: 120px 40px; }
.container { max-width: 1280px; margin: 0 auto; }
.section-eyebrow { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 20px; display: inline-flex; align-items: center; gap: 12px; }
.section-eyebrow::before { content: ''; width: 24px; height: 1px; background: var(--accent); }
.section-title { font-family: var(--serif); font-weight: 400; font-size: clamp(32px, 4vw, 52px); line-height: 1.1; letter-spacing: -0.02em; max-width: 800px; margin-bottom: 24px; }
.section-title em { color: var(--accent); font-style: italic; }
.section-lead { font-size: 17px; color: var(--ink-soft); max-width: 580px; line-height: 1.7; }

/* ABOUT */
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end; margin-top: 60px; }
.about-visual { position: relative; aspect-ratio: 4/5; width: 100%; overflow: hidden; background: var(--ink); display: block; }
.about-visual img { width: 100%; height: 100%; object-fit: cover; transition: transform 8s ease, filter 0.6s ease; filter: grayscale(40%) contrast(1.05); display: block; }
.about-visual:hover img { transform: scale(1.04); filter: grayscale(0%) contrast(1.05); }
.about-visual::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.55), transparent 50%); pointer-events: none; }
.about-visual-overlay { position: absolute; bottom: 32px; left: 32px; right: 32px; color: var(--paper); display: flex; justify-content: space-between; align-items: end; pointer-events: none; z-index: 1; }
.about-visual .since-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.7; margin-bottom: 4px; }
.about-visual .since { font-family: var(--serif); font-size: 56px; font-weight: 500; letter-spacing: -0.03em; line-height: 1; }
.about-visual .badge { font-family: var(--serif); font-size: 14px; font-style: italic; }
.about-text p { font-size: 16px; line-height: 1.8; color: var(--ink-soft); margin-bottom: 20px; }
.about-text p:first-child { font-family: var(--serif); font-size: 22px; line-height: 1.5; color: var(--ink); }
.about-list { margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--line); display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.about-list-item { font-size: 14px; color: var(--ink-soft); display: flex; align-items: flex-start; gap: 10px; }
.about-list-item::before { content: ''; width: 4px; height: 4px; border-radius: 50%; background: var(--accent); margin-top: 9px; flex-shrink: 0; }

/* SERVICES */
.services { background: var(--paper); }
.services-list { margin-top: 80px; border-top: 1px solid var(--line); }
.service-row { display: grid; grid-template-columns: 80px 1fr 2fr 60px; align-items: center; gap: 40px; padding: 32px 0; border-bottom: 1px solid var(--line); cursor: pointer; transition: padding 0.4s; position: relative; }
.service-row:hover { padding-left: 24px; }
.service-row::after { content: ''; position: absolute; left: 0; top: 0; width: 0; height: 100%; background: var(--accent-soft); z-index: -1; transition: width 0.4s; }
.service-row:hover::after { width: 100%; }
.service-num { font-family: var(--serif); font-size: 14px; color: var(--ink-muted); }
.service-name { font-family: var(--serif); font-size: 28px; font-weight: 400; letter-spacing: -0.01em; transition: color 0.3s; }
.service-row:hover .service-name { color: var(--accent); }
.service-desc { font-size: 15px; color: var(--ink-soft); line-height: 1.6; }
.service-arrow { text-align: right; font-family: var(--serif); font-size: 24px; color: var(--ink-muted); transition: transform 0.4s, color 0.3s; }
.service-row:hover .service-arrow { transform: translateX(8px); color: var(--accent); }

/* INSIGHTS */
.insights-header { display: flex; justify-content: space-between; align-items: end; margin-bottom: 60px; }
.insights-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
.insight { display: flex; flex-direction: column; transition: opacity 0.3s; }
.insight-image { aspect-ratio: 4/3; width: 100%; overflow: hidden; background: var(--ink); margin-bottom: 24px; display: block; }
.insight-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.2s ease, filter 0.6s ease; filter: grayscale(30%); display: block; }
.insight:hover .insight-image img { transform: scale(1.06); filter: grayscale(0%); }
.insight-meta { display: flex; justify-content: space-between; font-size: 12px; color: var(--ink-muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
.insight h3 { font-family: var(--serif); font-size: 22px; font-weight: 400; line-height: 1.3; letter-spacing: -0.01em; margin-bottom: 14px; }
.insight p { font-size: 14px; color: var(--ink-soft); line-height: 1.6; margin-bottom: 20px; flex: 1; }
.insight-link { font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 8px; transition: gap 0.3s, color 0.3s; }
.insight:hover .insight-link { gap: 14px; color: var(--accent); }

/* INDUSTRIES */
.industries { background: var(--ink); color: var(--paper); padding: 100px 0; overflow: hidden; position: relative; }
.industries::before { content: ''; position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1577415124269-fc1140a69e91?w=1600&q=80'); background-size: cover; background-position: center; opacity: 0.15; filter: grayscale(100%); }
.industries .container { padding: 0 40px; position: relative; z-index: 1; }
.industries .section-eyebrow { color: rgba(255,255,255,0.5); }
.industries .section-title { color: var(--paper); }
.industries .section-lead { color: rgba(255,255,255,0.65); }
.ticker { margin-top: 80px; display: flex; gap: 60px; animation: scroll 40s linear infinite; width: max-content; position: relative; z-index: 1; }
.ticker-item { font-family: var(--serif); font-size: 56px; font-weight: 400; letter-spacing: -0.02em; white-space: nowrap; display: flex; align-items: center; gap: 60px; color: rgba(255,255,255,0.85); }
.ticker-item::after { content: '✦'; color: var(--accent); font-size: 24px; }
@keyframes scroll { to { transform: translateX(-50%); } }

/* CONTACT */
.contact { background: var(--paper); }
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-top: 60px; }
.contact-info h3 { font-family: var(--serif); font-size: 28px; font-weight: 400; margin-bottom: 24px; letter-spacing: -0.01em; }
.office-list { display: grid; }
.office { padding: 24px 0; border-top: 1px solid var(--line); display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: center; }
.office:last-child { border-bottom: 1px solid var(--line); }
.office-city { font-family: var(--serif); font-size: 20px; font-weight: 500; }
.office-detail { font-size: 14px; color: var(--ink-soft); line-height: 1.6; }
.office-detail a { transition: color 0.2s; }
.office-detail a:hover { color: var(--accent); }
.contact-form { background: var(--bg); padding: 48px; border: 1px solid var(--line); }
.contact-form h3 { font-family: var(--serif); font-size: 28px; font-weight: 400; margin-bottom: 32px; letter-spacing: -0.01em; }
.form-field { margin-bottom: 24px; }
.form-field label { display: block; font-size: 12px; color: var(--ink-muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
.form-field input, .form-field textarea { width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--line); padding: 12px 0; font-size: 16px; font-family: var(--sans); color: var(--ink); outline: none; transition: border-color 0.3s; }
.form-field input:focus, .form-field textarea:focus { border-color: var(--accent); }
.form-field textarea { resize: vertical; min-height: 80px; }

/* FOOTER */
.footer { background: var(--bg); padding: 80px 40px 32px; border-top: 1px solid var(--line); }
.footer-inner { max-width: 1280px; margin: 0 auto; }
.footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; padding-bottom: 60px; border-bottom: 1px solid var(--line); }
.footer-brand p { margin-top: 20px; max-width: 320px; font-size: 14px; color: var(--ink-soft); line-height: 1.7; }
.footer-col h5 { font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 20px; font-weight: 500; }
.footer-col a { display: block; font-size: 14px; color: var(--ink-soft); padding: 6px 0; transition: color 0.2s; }
.footer-col a:hover { color: var(--accent); }
.footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 32px; font-size: 13px; color: var(--ink-muted); }
.footer-bottom-links { display: flex; gap: 24px; }
.footer-bottom-links a:hover { color: var(--ink); }

/* ANIMATIONS */
@keyframes rise { to { opacity: 1; transform: translateY(0); } }
.reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.9s ease, transform 0.9s ease; }
.reveal.in { opacity: 1; transform: translateY(0); }

/* RESPONSIVE */
@media (max-width: 900px) {
  .header-inner { padding: 16px 20px; }
  nav { display: none; }
  .burger { display: block; }
  .cta-btn { display: none; }
  .hero { padding: 120px 20px 60px; }
  .hero-grid { grid-template-columns: 1fr; gap: 48px; }
  .hero-visual { aspect-ratio: 4/3; }
  .hero-meta { grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 60px; }
  section { padding: 80px 20px; }
  .about-grid { grid-template-columns: 1fr; gap: 48px; }
  .about-visual .since { font-size: 44px; }
  .about-list { grid-template-columns: 1fr; gap: 16px; }
  .service-row { grid-template-columns: 40px 1fr 30px; gap: 16px; padding: 24px 0; }
  .service-desc { display: none; }
  .service-name { font-size: 20px; }
  .insights-header { flex-direction: column; align-items: flex-start; gap: 24px; }
  .insights-grid { grid-template-columns: 1fr; gap: 32px; }
  .ticker-item { font-size: 32px; gap: 32px; }
  .ticker { gap: 32px; }
  .contact-grid { grid-template-columns: 1fr; gap: 48px; }
  .office { grid-template-columns: 1fr; gap: 8px; }
  .contact-form { padding: 32px 24px; }
  .footer { padding: 60px 20px 24px; }
  .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
}
@media (max-width: 500px) {
  .footer-top { grid-template-columns: 1fr; }
}
</style>
</head>
